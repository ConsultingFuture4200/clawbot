# ClawBot — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git — only .env.example

# =============================================================================
# Google Gemini (Primary workhorse — free tier from AI Studio)
# Get key: https://aistudio.google.com/apikey
# =============================================================================
GEMINI_API_KEY=

# =============================================================================
# Anthropic Claude (On-demand complex reasoning — pay-per-token)
# Get key: https://console.anthropic.com/settings/keys
# Budget cap: $30/month
# =============================================================================
ANTHROPIC_API_KEY=

# =============================================================================
# OpenAI API (Embeddings only — Codex uses OAuth, not this key)
# Get key: https://platform.openai.com/api-keys
# Model: text-embedding-3-small (~$0.02/M tokens)
# =============================================================================
OPENAI_API_KEY=

# =============================================================================
# Telegram Bot
# Create via @BotFather in Telegram
# =============================================================================
TELEGRAM_BOT_TOKEN=

# =============================================================================
# Ollama (Local LLM — auto-detected, usually no change needed)
# =============================================================================
OLLAMA_HOST=http://127.0.0.1:11434

# =============================================================================
# GitHub (Fine-grained PAT — all personal repos)
# Create: https://github.com/settings/tokens?type=beta
# Scopes: read/write issues, read/write PRs, read contents, webhooks
# =============================================================================
GITHUB_TOKEN=

# =============================================================================
# Gmail OAuth2 (Desktop App — from GCP Console)
# Create: https://console.cloud.google.com/ -> APIs & Services -> Credentials
# App type: Desktop app
# Required APIs: Gmail API, Google Calendar API
# Consent screen: MUST be set to Production mode (not Testing)
# See .planning/phases/01-gmail-foundation/01-RESEARCH.md Pitfall #1
# =============================================================================
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
# Note: Refresh tokens stored by gog CLI at ~/.config/gog/
# These vars are for direct googleapis npm access if needed

# =============================================================================
# Home Assistant (Phase 2/3 — leave blank until HA is running)
# =============================================================================
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=
